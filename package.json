{
  "name": "pacbecca",
  "version": "0.5.6",
  "private": true,
  "description": "PacBecca, an original maze-chase browser game inspired by classic arcade design.",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc --noEmit && vite build",
    "build:squarespace": "vite build --config vite.squarespace.config.ts",
    "build:squarespace:embed": "node scripts/build-squarespace-embed.mjs",
    "preview": "vite preview --host 127.0.0.1",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "version:check": "node scripts/check-version.mjs",
    "check": "pnpm version:check && pnpm test && pnpm build",
    "deploy:production": "node scripts/deploy-production.mjs",
    "leaderboard:dev": "pnpm dlx wrangler dev --config workers/leaderboard/wrangler.toml",
    "leaderboard:deploy": "pnpm dlx wrangler deploy --config workers/leaderboard/wrangler.toml"
  },
  "dependencies": {
    "phaser": "^3.90.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.8.3",
    "vite": "^7.0.0",
    "vitest": "^3.2.4"
  },
  "packageManager": "pnpm@11.7.0"
}
