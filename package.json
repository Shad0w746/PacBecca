{
  "name": "pacbecca",
  "version": "0.1.0",
  "private": true,
  "description": "PacBecca, an original maze-chase browser game inspired by classic arcade design.",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "check": "pnpm test && pnpm build"
  },
  "dependencies": {
    "phaser": "^3.90.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.8.3",
    "vite": "^7.0.0",
    "vitest": "^3.2.4"
  },
  "packageManager": "pnpm@11.7.0"
}
